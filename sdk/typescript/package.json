{
  "name": "darkmatter-js",
  "version": "1.2.0",
  "description": "TypeScript/Node.js SDK for DarkMatter — execution records for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build":          "tsc",
    "test":           "ts-node src/integrity.test.ts",
    "prepublishOnly": "npm run test && npm run build"
  },
  "exports": {
    ".": {
      "import":  "./dist/index.js",
      "require": "./dist/index.js",
      "types":   "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "keywords": ["darkmatter", "ai", "agents", "execution", "lineage", "replay", "fork", "verify", "audit"],
  "author": "DarkMatter <hello@darkmatterhub.ai>",
  "license": "MIT",
  "homepage": "https://darkmatterhub.ai",
  "repository": { "type": "git", "url": "https://github.com/bengunvl/darkmatter" },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "ts-node":     "^10.9.0"
  },
  "engines": { "node": ">=18.0.0" }
}
